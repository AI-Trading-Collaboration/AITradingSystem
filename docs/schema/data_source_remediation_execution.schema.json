{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Source Remediation Execution",
  "type": "object",
  "required": [
    "report_type",
    "status",
    "summary",
    "source_acceptance_report_path",
    "source_qualification_matrix_path",
    "source_remediation_plan_path",
    "source_acceptance_summary_updated_path",
    "source_acceptance_rerun_report_path",
    "item_results_path",
    "updated_matrix_path",
    "remediation_item_results",
    "production_effect",
    "broker_action",
    "promotion_gate_allowed",
    "paper_shadow_change_allowed",
    "production_weight_change_allowed",
    "lookahead_violation_count"
  ],
  "properties": {
    "report_type": {"const": "data_source_remediation_execution_report"},
    "production_effect": {"const": "none"},
    "broker_action": {"const": "none"},
    "promotion_gate_allowed": {"const": false},
    "paper_shadow_change_allowed": {"const": false},
    "production_weight_change_allowed": {"const": false},
    "lookahead_violation_count": {"const": 0},
    "summary": {
      "type": "object",
      "required": [
        "matrix_status",
        "promotion_grade_ready_count",
        "diagnostic_only_count",
        "blocked_until_qualified_count",
        "current_view_only_count",
        "research_label_only_count",
        "lookahead_violation_count",
        "P0_remaining_count",
        "P0_resolved_count",
        "production_effect",
        "broker_action",
        "promotion_gate_allowed",
        "paper_shadow_change_allowed",
        "production_weight_change_allowed"
      ],
      "properties": {
        "production_effect": {"const": "none"},
        "broker_action": {"const": "none"},
        "promotion_gate_allowed": {"const": false},
        "paper_shadow_change_allowed": {"const": false},
        "production_weight_change_allowed": {"const": false},
        "lookahead_violation_count": {"const": 0}
      }
    },
    "remediation_item_results": {
      "type": "array",
      "items": {"$ref": "#/$defs/remediationExecutionResult"},
      "minItems": 1
    }
  },
  "$defs": {
    "remediationExecutionResult": {
      "type": "object",
      "required": [
        "component",
        "priority",
        "before_status",
        "after_status",
        "blocked_reason",
        "fix_applied",
        "remaining_gap",
        "repairable_without_relaxing_gate",
        "promotion_grade_candidate_after_fix",
        "allowed_uses",
        "strategy_input_allowed",
        "promotion_evidence_allowed",
        "source_input_allowed",
        "gate_relaxation_allowed",
        "production_effect",
        "broker_action",
        "promotion_gate_allowed",
        "paper_shadow_change_allowed",
        "production_weight_change_allowed",
        "lookahead_violation_count"
      ],
      "properties": {
        "before_status": {
          "enum": [
            "DIAGNOSTIC_ONLY",
            "BLOCKED_UNTIL_QUALIFIED",
            "RESEARCH_LABEL_ONLY",
            "CURRENT_VIEW_ONLY",
            "UNKNOWN_REQUIRES_MANUAL_REVIEW"
          ]
        },
        "after_status": {
          "enum": [
            "DIAGNOSTIC_ONLY",
            "BLOCKED_UNTIL_QUALIFIED",
            "RESEARCH_LABEL_ONLY",
            "CURRENT_VIEW_ONLY",
            "UNKNOWN_REQUIRES_MANUAL_REVIEW"
          ]
        },
        "strategy_input_allowed": {"const": false},
        "promotion_evidence_allowed": {"const": false},
        "source_input_allowed": {"const": false},
        "gate_relaxation_allowed": {"const": false},
        "production_effect": {"const": "none"},
        "broker_action": {"const": "none"},
        "promotion_gate_allowed": {"const": false},
        "paper_shadow_change_allowed": {"const": false},
        "production_weight_change_allowed": {"const": false},
        "lookahead_violation_count": {"const": 0}
      }
    }
  }
}
