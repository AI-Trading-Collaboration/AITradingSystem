{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PIT Feature Record",
  "type": "object",
  "required": [
    "feature_id",
    "asset_id",
    "as_of_date",
    "decision_time",
    "raw_value",
    "normalized_value",
    "feature_family",
    "source",
    "source_dataset",
    "source_version",
    "raw_event_time",
    "available_time",
    "revision_policy",
    "as_reported",
    "current_view",
    "snapshot_id",
    "snapshot_hash",
    "lookahead_risk",
    "quality_flags"
  ],
  "properties": {
    "feature_id": {"type": "string"},
    "asset_id": {"type": "string"},
    "as_of_date": {"type": "string"},
    "decision_time": {"type": "string"},
    "feature_family": {"type": "string"},
    "as_reported": {"type": "boolean"},
    "current_view": {"type": "boolean"},
    "lookahead_risk": {"type": "string"},
    "quality_flags": {"type": "array", "items": {"type": "string"}}
  }
}
