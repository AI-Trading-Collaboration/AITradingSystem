{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Foundation Remediation Plan",
  "type": "object",
  "required": [
    "report_type",
    "status",
    "summary",
    "P0_remediation_priorities",
    "remediation_items",
    "blocked_until_qualified_items",
    "diagnostic_only_items",
    "current_view_only_items",
    "source_acceptance_report_path",
    "production_effect",
    "broker_action",
    "promotion_gate_allowed",
    "paper_shadow_change_allowed",
    "production_weight_change_allowed",
    "lookahead_violation_count"
  ],
  "properties": {
    "report_type": {"const": "data_foundation_remediation_plan"},
    "production_effect": {"const": "none"},
    "broker_action": {"const": "none"},
    "promotion_gate_allowed": {"const": false},
    "paper_shadow_change_allowed": {"const": false},
    "production_weight_change_allowed": {"const": false},
    "lookahead_violation_count": {"const": 0},
    "summary": {
      "type": "object",
      "required": [
        "P0_item_count",
        "repairable_without_relaxing_gate_count",
        "expected_promotion_grade_gain_if_fixed",
        "no_gate_relaxation",
        "production_effect",
        "broker_action",
        "promotion_gate_allowed",
        "paper_shadow_change_allowed",
        "production_weight_change_allowed",
        "lookahead_violation_count"
      ],
      "properties": {
        "no_gate_relaxation": {"const": true},
        "production_effect": {"const": "none"},
        "broker_action": {"const": "none"},
        "promotion_gate_allowed": {"const": false},
        "paper_shadow_change_allowed": {"const": false},
        "production_weight_change_allowed": {"const": false},
        "lookahead_violation_count": {"const": 0}
      }
    },
    "P0_remediation_priorities": {
      "type": "array",
      "items": {"$ref": "#/$defs/p0Priority"},
      "minItems": 5
    },
    "remediation_items": {
      "type": "array",
      "items": {"$ref": "#/$defs/remediationItem"},
      "minItems": 1
    },
    "blocked_until_qualified_items": {
      "type": "array",
      "items": {"$ref": "#/$defs/remediationItem"}
    },
    "diagnostic_only_items": {
      "type": "array",
      "items": {"$ref": "#/$defs/remediationItem"}
    },
    "current_view_only_items": {
      "type": "array",
      "items": {"$ref": "#/$defs/remediationItem"}
    }
  },
  "$defs": {
    "p0Priority": {
      "type": "object",
      "required": ["source_family", "required_fix", "priority"],
      "properties": {
        "priority": {"const": "P0"},
        "source_family": {
          "enum": [
            "price / adjusted price / corporate actions",
            "SEC / fundamental PIT availability",
            "asset master / ticker / tradability",
            "event labels as-known-before vs post-hoc",
            "cost / spread / liquidity assumptions"
          ]
        }
      }
    },
    "remediationItem": {
      "type": "object",
      "required": [
        "component",
        "current_status",
        "blocked_reason",
        "missing_contract",
        "missing_source_manifest",
        "missing_available_time",
        "current_view_only_risk",
        "lineage_gap",
        "PIT_risk",
        "repairable_without_relaxing_gate",
        "required_fix",
        "expected_promotion_grade_gain_if_fixed",
        "gate_relaxation_allowed",
        "production_effect",
        "broker_action",
        "promotion_gate_allowed",
        "paper_shadow_change_allowed",
        "production_weight_change_allowed",
        "lookahead_violation_count"
      ],
      "properties": {
        "current_status": {
          "enum": [
            "DIAGNOSTIC_ONLY",
            "BLOCKED_UNTIL_QUALIFIED",
            "RESEARCH_LABEL_ONLY",
            "CURRENT_VIEW_ONLY",
            "UNKNOWN_REQUIRES_MANUAL_REVIEW"
          ]
        },
        "PIT_risk": {"enum": ["LOW", "MEDIUM", "HIGH"]},
        "gate_relaxation_allowed": {"const": false},
        "production_effect": {"const": "none"},
        "broker_action": {"const": "none"},
        "promotion_gate_allowed": {"const": false},
        "paper_shadow_change_allowed": {"const": false},
        "production_weight_change_allowed": {"const": false},
        "lookahead_violation_count": {"const": 0}
      }
    }
  }
}
