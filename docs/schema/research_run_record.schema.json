{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Run Record",
  "type": "object",
  "required": [
    "run_id",
    "research_id",
    "strategy_id",
    "strategy_family",
    "run_type",
    "dataset_version",
    "feature_snapshot_id",
    "asset_universe_version",
    "cost_model_version",
    "label_version",
    "config_hash",
    "code_version",
    "policy_version",
    "time_split",
    "horizon_set",
    "evaluation_stage",
    "metrics_summary",
    "artifact_paths",
    "evidence_ids",
    "decision_record_id",
    "promotion_gate_allowed",
    "paper_shadow_change_allowed",
    "production_effect",
    "created_at"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "promotion_gate_allowed": {"type": "boolean"},
    "paper_shadow_change_allowed": {"type": "boolean"},
    "production_effect": {"const": "none"}
  }
}
